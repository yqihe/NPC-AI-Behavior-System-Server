{
  "component": "memory",
  "display_name": "记忆组件",
  "blackboard_keys": ["memory_count"],
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["capacity", "memory_types", "decay_time"],
    "properties": {
      "capacity": {
        "type": "integer",
        "title": "记忆容量",
        "description": "最大记忆条目数，满后淘汰最旧条目",
        "minimum": 1
      },
      "memory_types": {
        "type": "array",
        "title": "记忆类型",
        "description": "该 NPC 支持的记忆类型列表",
        "minItems": 1,
        "items": {
          "type": "string",
          "enum": ["threat", "location", "social"]
        }
      },
      "decay_time": {
        "type": "number",
        "title": "记忆衰减时间",
        "description": "记忆默认 TTL（秒），到期自动遗忘",
        "minimum": 0
      }
    }
  }
}