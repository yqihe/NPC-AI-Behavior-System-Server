{
  "component": "identity",
  "display_name": "身份组件",
  "blackboard_keys": ["npc_type"],
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["name", "model_id"],
    "properties": {
      "name": {
        "type": "string",
        "title": "显示名称",
        "description": "NPC 在游戏中的显示名称",
        "minLength": 1
      },
      "model_id": {
        "type": "string",
        "title": "模型 ID",
        "description": "对应客户端模型资源的标识符",
        "minLength": 1
      },
      "tags": {
        "type": "array",
        "title": "标签",
        "description": "用于分类和查询的标签列表（如 ambient、predator、friendly）",
        "items": { "type": "string" },
        "default": []
      }
    }
  }
}